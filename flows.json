        "y": 600,
        "wires": []
    },
    {
        "id": "4b8b863566f324b0",
        "type": "function",
        "z": "72c7cdedf43b6708",
        "name": "Preparar INSERT SQL",
        "func": "var temp = flow.get('ultima_temp');\nvar luz = flow.get('ultima_luz');\nif (temp === undefined && luz === undefined) return null;\n\nmsg.query = \"INSERT INTO leituras (sensor, valor) VALUES (:1, :2)\";\nmsg.params = [msg.topic === 'temperatura' ? 'temperatura' : 'luminosidade', msg.payload];\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 370,
        "y": 660,
