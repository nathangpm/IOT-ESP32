    {
        "id": "017c7ce007dc9b1a",
        "type": "function",
        "z": "72c7cdedf43b6708",
        "name": "Formatar Clima",
        "func": "var d = msg.payload;\n\n// Verifica se a API retornou dados validos\nif (!d || !d.main) {\n    node.warn('Resposta invalida da API OpenWeather: ' + JSON.stringify(d));\n    msg.payload = 'Erro ao buscar clima. Verifique sua chave da API.';\n    return msg;\n}\n\n// Capitaliza primeira letra\nvar cap = function(s) {\n    return s.charAt(0).toUpperCase() + s.slice(1);\n};\n\nvar linha1 = '🌡️ Temperatura: ' + d.main.temp + '°C';\nvar linha2 = '🌡️ Sensacao termica: ' + d.main.feels_like + '°C';\nvar linha3 = '🌤️ ' + cap(d.weather[0].description);\nvar linha4 = '💧 Umidade: ' + d.main.humidity + '%';\nvar linha5 = '💨 Vento: ' + d.wind.speed + ' m/s';\nvar linha6 = '📍 ' + d.name;\n\nmsg.payload = linha1 + '\\n' + linha2 + '\\n' + linha3 + '\\n' + linha4 + '\\n' + linha5 + '\\n' + linha6;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 560,
        "y": 500,
        "wires": [
            [
                "c1912f7b250ad24b"
            ]
        ]
    },
