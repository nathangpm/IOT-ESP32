    {
        "id": "fa8e6d30b8cc9f72",
        "type": "comment",
        "z": "72c7cdedf43b6708",
        "name": "=== ETAPA 2: PROCESSAMENTO ===",
        "info": "Converte payload string para numero e salva em contexto",
        "x": 400,
        "y": 40,
        "wires": []
    },
    {
        "id": "3c3dbf3d635750d3",
        "type": "function",
        "z": "72c7cdedf43b6708",
        "name": "Parse Temperatura",
        "func": "var data = msg.payload;\nif (typeof data === 'string') data = JSON.parse(data);\nvar val = Number(data.temperatura);\nif (isNaN(val)) return null;\nflow.set('ultima_temp', val);\nmsg.payload = val;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 370,
        "y": 100,
        "wires": [
            [
                "e7e9108d6d5c90b0",
                "adb9049e7f23640e",
                "4b8b863566f324b0"
            ]
        ]
    },
    {
        "id": "1859745ccefdc8f5",
        "type": "function",
        "z": "72c7cdedf43b6708",
        "name": "Parse Luminosidade",
        "func": "var data = msg.payload;\nif (typeof data === 'string') data = JSON.parse(data);\nvar val = Number(data.luminosidade);\nif (isNaN(val)) return null;\nflow.set('ultima_luz', val);\nmsg.payload = val;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
